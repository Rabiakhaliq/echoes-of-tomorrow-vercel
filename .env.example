# --- Backend (used by /api functions and dev-server.js) ---

# MongoDB Atlas connection string
MONGO_URI=mongodb+srv://<username>:<password>@<cluster-url>/echoes-of-tomorrow?retryWrites=true&w=majority

# Any long random string — used to sign login tokens
JWT_SECRET=replace_this_with_a_long_random_string

# Optional — protects the /api/cron/check-letters endpoint from random requests.
# Set the same value here and in Vercel's environment variables.
CRON_SECRET=replace_this_with_another_random_string

# Optional — only needed for real "letter arrived" emails.
# Use a Gmail App Password (not your normal password): https://myaccount.google.com/apppasswords
EMAIL_USER=
EMAIL_PASS=

PORT=5000

# --- Frontend ---
# Leave unset locally (defaults to http://localhost:5000/api).
# Leave unset in Vercel too — production automatically uses a relative /api path.
# VITE_API_URL=
